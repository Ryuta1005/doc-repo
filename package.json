{
  "name": "doc-repo",
  "version": "0.3.0-alpha.0",
  "description": "Browse and edit repository Markdown in a browser while keeping Git and Markdown as the source of truth.",
  "keywords": [
    "markdown",
    "documentation",
    "cli",
    "repository",
    "docs"
  ],
  "license": "MIT",
  "author": {
    "name": "Ryuta Otsuka",
    "url": "https://github.com/Ryuta1005"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ryuta1005/doc-repo.git"
  },
  "bugs": {
    "url": "https://github.com/Ryuta1005/doc-repo/issues"
  },
  "homepage": "https://github.com/Ryuta1005/doc-repo#readme",
  "type": "module",
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "bin": {
    "doc-repo": "dist/cli/index.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "npm run clean",
    "build": "npm run build:tsc --",
    "postbuild": "npm run build:viewer",
    "build:tsc": "tsc -p tsconfig.build.json",
    "build:viewer": "vite build --config vite.viewer.config.ts",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.viewer.json && tsc -p tsconfig.tests.json",
    "test": "vitest run --coverage",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.5",
    "hono": "^4.12.25",
    "lucide-react": "^1.18.0",
    "markdown-it": "^14.2.0",
    "micromatch": "^4.0.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/fs-extra": "^11.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/markdown-it": "^14.1.2",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
